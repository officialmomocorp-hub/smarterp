// Indian School ERP - Prisma Schema (PostgreSQL Production)
// Supports CBSE, ICSE, State Boards - Indian Education System

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// SCHOOL & ACADEMIC STRUCTURE
// ==========================================

model School {
  id                 String         @id @default(uuid())
  name               String
  code               String         @unique
  address            String
  city               String
  state              String
  pincode            String
  phone              String
  email              String
  website            String?
  udiseCode          String         @unique
  affiliationNumber  String?
  schoolType         String         @default("Co-Educational")
  mediumOfInstruction String        @default("English")
  logoUrl            String?
  letterheadUrl      String?
  principalName      String?
  principalPhotoUrl  String?
  establishmentYear  Int?
  minorityStatus     Boolean        @default(false)
  minorityType       String?
  rteApproved        Boolean        @default(true)
  midDayMealEnabled  Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  academicYears      AcademicYear[]
  users              User[]
  classes            Class[]
  holidays           Holiday[]
  notices            Notice[]
  communications     Communication[]
}

model AcademicYear {
  id          String    @id @default(uuid())
  schoolId    String
  name        String
  startDate   DateTime
  endDate     DateTime
  status      String    @default("ACTIVE")
  isCurrent   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  school      School    @relation(fields: [schoolId], references: [id])
  classes     Class[]
  admissions  Admission[]
  feePayments FeePayment[]
  exams       Exam[]
  students    Student[]
  payrollRecords PayrollRecord[]

  @@index([schoolId, isCurrent])
}

model Class {
  id              String    @id @default(uuid())
  schoolId        String
  academicYearId  String
  name            String
  displayName     String
  sortOrder       Int
  hasCce          Boolean   @default(false)
  isBoardClass    Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  school          School    @relation(fields: [schoolId], references: [id])
  academicYear      AcademicYear    @relation(fields: [academicYearId], references: [id])
  sections        Section[]
  subjects        Subject[]
  students        Student[]
  feeStructures   FeeStructure[]
  timetables      Timetable[]
  exams           Exam[]

  @@index([schoolId, academicYearId])
}

model Section {
  id          String    @id @default(uuid())
  classId     String
  name        String
  capacity    Int       @default(40)
  roomNumber  String?
  classTeacherId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  class       Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  students    Student[]
  timetables  Timetable[]
  subjects    Subject[]

  @@index([classId])
}

model Subject {
  id          String    @id @default(uuid())
  classId     String
  sectionId   String?
  name        String
  code        String
  maxMarks    Int       @default(100)
  passMarks   Int       @default(33)
  type        String    @default("Theory")
  teacherId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  class       Class     @relation(fields: [classId], references: [id])
  section     Section?  @relation(fields: [sectionId], references: [id])
  teacher     User?     @relation("SubjectTeacher", fields: [teacherId], references: [id])
  marks       Mark[]
  homeworks   Homework[]
  examSubjects ExamSubject[]

  @@index([classId])
  @@index([teacherId])
}

// ==========================================
// USER & AUTHENTICATION
// ==========================================

model User {
  id                String    @id @default(uuid())
  schoolId          String
  email             String?
  phone             String
  password          String
  role              String
  tokenVersion      Int       @default(0)
  isActive          Boolean   @default(true)
  lastLogin         DateTime?
  failedLoginAttempts Int     @default(0)
  lockedUntil       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  school            School    @relation(fields: [schoolId], references: [id])
  profile           Profile?
  student           Student?
  parent            Parent?
  staff             Staff?
  subjectsTaught    Subject[] @relation("SubjectTeacher")
  attendanceRecords Attendance[]
  leaves            LeaveApplication[]
  marksEntered      Mark[]    @relation("MarkEnteredBy")
  salaries          Salary[]
  auditLogs         AuditLog[]
  sentCommunications Communication[] @relation("CommSender")
  passwordHistory   PasswordHistory[]

  @@index([schoolId, role])
  @@index([email])
  @@index([phone])
}

model Profile {
  id              String    @id @default(uuid())
  userId          String    @unique
  firstName       String
  middleName      String?
  lastName        String
  dateOfBirth     DateTime
  gender          String
  bloodGroup      String?
  photoUrl        String?
  address         String?
  city            String?
  state           String?
  pincode         String?
  emergencyPhone  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ==========================================
// ADMISSION MANAGEMENT
// ==========================================

model Admission {
  id                String          @id @default(uuid())
  schoolId          String
  academicYearId    String
  admissionNumber   String          @unique
  applicantName     String
  applicantPhone    String
  applicantEmail    String?
  classApplied      String
  sectionPreferred  String?
  dateOfBirth       DateTime
  gender            String
  casteCategory     String
  religion          String
  motherTongue      String
  aadharNumber      String?
  previousSchool    String?
  previousClass     String?
  tcNumber          String?
  tcDate            DateTime?
  reasonForLeaving  String?
  fatherName        String?
  fatherOccupation  String?
  fatherPhone       String?
  motherName        String?
  motherOccupation  String?
  motherPhone       String?
  annualIncome      Float?
  address           String?
  city              String?
  state             String?
  pincode           String?
  status            String          @default("PENDING")
  remarks           String?
  documents         String?
  admissionFeePaid  Boolean         @default(false)
  admissionFeeAmount Float?
  submittedAt       DateTime        @default(now())
  processedAt       DateTime?
  processedBy       String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  academicYear      AcademicYear    @relation(fields: [academicYearId], references: [id])
  student           Student?

  @@index([schoolId, status])
  @@index([admissionNumber])
}

// ==========================================
// STUDENT MANAGEMENT
// ==========================================

model Student {
  id                String    @id @default(uuid())
  userId            String?   @unique
  schoolId          String
  admissionId       String?   @unique
  studentId         String
  udiseNumber       String?
  classId           String
  sectionId         String
  rollNumber        Int
  academicYearId    String
  status            String    @default("ACTIVE")
  dateOfAdmission   DateTime  @default(now())
  dateOfLeaving     DateTime?
  leavingReason     String?
  house             String?
  bplStatus         Boolean   @default(false)
  bankAccountNumber String?
  bankIfsc          String?
  bankName          String?
  scholarshipEligible Boolean @default(false)
  scholarshipType   String?
  rteSeat           Boolean   @default(false)
  midDayMealOpted   Boolean   @default(true)
  transportOpted    Boolean   @default(false)
  transportRouteId  String?
  hostelOpted       Boolean   @default(false)
  hostelRoomId      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user              User?     @relation(fields: [userId], references: [id])
  class             Class     @relation(fields: [classId], references: [id])
  section           Section   @relation(fields: [sectionId], references: [id])
  academicYear      AcademicYear @relation(fields: [academicYearId], references: [id])
  admission         Admission?  @relation(fields: [admissionId], references: [id])
  profile           StudentProfile?
  parents           ParentStudent[]
  attendance        Attendance[]
  feePayments       FeePayment[]
  marks             Mark[]
  bookIssues        BookIssue[]
  leaves            LeaveApplication[]
  homeworks         HomeworkSubmission[]
  hostelAllotment   HostelAllotment?
  transportRoute    TransportRoute? @relation(fields: [transportRouteId], references: [id])
  seatingArrangements SeatingArrangement[]
  healthRecords     StudentHealthRecord[]
  meritCertificates MeritCertificate[]
  recheckApplications RecheckApplication[]

  // @@unique([schoolId, academicYearId, classId, sectionId, rollNumber])
  @@index([schoolId, classId, sectionId])
  @@index([studentId])
  @@index([academicYearId])
  @@index([status])
}

model StudentProfile {
  id                String    @id @default(uuid())
  studentId         String    @unique
  firstName         String
  middleName        String?
  lastName          String
  dateOfBirth       DateTime
  gender            String
  casteCategory     String
  religion          String
  motherTongue      String
  aadharNumber      String
  bloodGroup        String?
  photoUrl          String?
  birthCertificateUrl String?
  aadharUrl         String?
  photo3x4Url       String?
  categoryCertificateUrl String?
  incomeCertificateUrl String?
  domicileCertificateUrl String?
  bplCardUrl        String?
  birthPlace        String?
  nationality       String    @default("Indian")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  student           Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

model Parent {
  id                String    @id @default(uuid())
  userId            String?   @unique
  schoolId          String
  fatherName        String
  fatherOccupation  String?
  fatherOrganization String?
  fatherIncome      Float?
  fatherPhone       String
  fatherEmail       String?
  fatherAadhar      String?
  motherName        String
  motherOccupation  String?
  motherOrganization String?
  motherIncome      Float?
  motherPhone       String
  motherEmail       String?
  motherAadhar      String?
  guardianName      String?
  guardianRelation  String?
  guardianPhone     String?
  guardianOccupation String?
  guardianIncome    Float?
  address           String
  city              String
  state             String
  pincode           String
  annualIncome      Float?
  incomeProofUrl    String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user              User?     @relation(fields: [userId], references: [id])
  students          ParentStudent[]

  @@index([schoolId])
  @@index([fatherPhone])
  @@index([motherPhone])
}

model ParentStudent {
  id        String   @id @default(uuid())
  parentId  String
  studentId String
  relation  String   @default("Parent")
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  parent    Parent   @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

// ==========================================
// ATTENDANCE MANAGEMENT
// ==========================================

model Attendance {
  id                String           @id @default(uuid())
  schoolId          String
  studentId         String?
  staffId           String?
  userId            String?
  date              DateTime
  period            Int?
  status            String
  remarks           String?
  markedBy          String
  markedAt          DateTime         @default(now())
  biometricId       String?
  checkInTime       DateTime?
  checkOutTime      DateTime?
  lateMinutes       Int?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  student           Student?         @relation(fields: [studentId], references: [id])
  staff             Staff?           @relation(fields: [staffId], references: [id])
  user              User?            @relation(fields: [userId], references: [id])

  @@index([schoolId, date])
  @@index([studentId, date])
  @@index([staffId, date])
}

model LeaveApplication {
  id                String       @id @default(uuid())
  schoolId          String
  studentId         String?
  staffId           String?
  userId            String?
  startDate         DateTime
  endDate           DateTime
  leaveType         String
  reason            String
  status            String       @default("PENDING")
  appliedBy         String
  approvedBy        String?
  approvedAt        DateTime?
  rejectionReason   String?
  attachmentUrl     String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  student           Student?     @relation(fields: [studentId], references: [id])
  staff             Staff?       @relation(fields: [staffId], references: [id])
  user              User?        @relation(fields: [userId], references: [id])

  @@index([schoolId, status])
  @@index([studentId])
  @@index([staffId])
}

model Holiday {
  id          String    @id @default(uuid())
  schoolId    String
  name        String
  date        DateTime
  type        String
  description String?
  isNational  Boolean   @default(false)
  isState     Boolean   @default(false)
  createdAt   DateTime  @default(now())

  school      School    @relation(fields: [schoolId], references: [id])

  @@index([schoolId, date])
}

// ==========================================
// FEE MANAGEMENT
// ==========================================

model FeeStructure {
  id                String    @id @default(uuid())
  schoolId          String
  academicYearId    String
  classId           String
  name              String
  feeHeads          String
  totalAmount       Float
  installmentType   String    @default("QUARTERLY")
  dueDates          String
  lateFinePerDay    Float     @default(0)
  gstPercentage     Float     @default(0)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  class             Class     @relation(fields: [classId], references: [id])
  feePayments       FeePayment[]
  concessions       FeeConcession[]

  @@index([schoolId, academicYearId, classId])
}

model FeeConcession {
  id                String    @id @default(uuid())
  feeStructureId    String
  name              String
  type              String
  discountType      String
  discountValue     Float
  applicableCaste   String
  applicableIncome  Float?
  maxDiscountAmount Float?
  description       String?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  feeStructure      FeeStructure @relation(fields: [feeStructureId], references: [id])
  feePayments       FeePayment[]

  @@index([feeStructureId])
}

model FeePayment {
  id                String          @id @default(uuid())
  schoolId          String
  academicYearId    String
  studentId         String
  feeStructureId    String
  concessionId      String?
  receiptNumber     String
  installmentNumber Int
  dueDate           DateTime
  paymentDate       DateTime?
  totalAmount       Float
  concessionAmount  Float           @default(0)
  gstAmount         Float           @default(0)
  lateFine          Float           @default(0)
  paidAmount        Float           @default(0)
  balanceAmount     Float
  status            String          @default("PENDING")
  paymentMode       String?
  transactionId     String?
  bankName          String?
  chequeNumber      String?
  chequeDate        DateTime?
  razorpayOrderId   String?
  razorpayPaymentId String?
  remarks           String?
  receiptUrl        String?
  createdBy         String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  student           Student         @relation(fields: [studentId], references: [id])
  feeStructure      FeeStructure    @relation(fields: [feeStructureId], references: [id])
  concession        FeeConcession?  @relation(fields: [concessionId], references: [id])
  academicYear      AcademicYear    @relation(fields: [academicYearId], references: [id])

  @@index([studentId, academicYearId])
  @@index([receiptNumber])
  @@index([status])
  @@index([dueDate])
}

model Scholarship {
  id                String          @id @default(uuid())
  schoolId          String
  studentId         String
  type              String
  name              String
  amount            Float
  academicYear      String
  status            String          @default("Active")
  sanctionedBy      String?
  sanctionedDate    DateTime?
  renewalDate       DateTime?
  remarks           String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([schoolId, studentId])
  @@index([type])
}

// ==========================================
// EXAMINATION & MARKS
// ==========================================

model Exam {
  id                String    @id @default(uuid())
  schoolId          String
  academicYearId    String
  classId           String
  name              String
  type              String
  startDate         DateTime
  endDate           DateTime
  maxMarks          Int       @default(100)
  passMarks         Int       @default(33)
  weightage         Float     @default(100)
  isCce             Boolean   @default(false)
  scholastic        Boolean   @default(true)
  coScholastic      Boolean   @default(false)
  resultsPublished  Boolean   @default(false)
  boardType         String?
  graceMarks        Float     @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  academicYear      AcademicYear @relation(fields: [academicYearId], references: [id])
  class             Class     @relation(fields: [classId], references: [id])
  marks             Mark[]
  examSubjects      ExamSubject[]
  schedules         ExamSchedule[]
  seatingArrangements SeatingArrangement[]
  invigilatorDuties InvigilatorDuty[]
  answerBooks       AnswerBook[]
  meritCertificates MeritCertificate[]
  recheckApplications RecheckApplication[]

  @@index([schoolId, academicYearId, classId])
}

model ExamSubject {
  id          String   @id @default(uuid())
  examId      String
  subjectId   String
  maxMarks    Int      @default(100)
  passMarks   Int      @default(33)
  createdAt   DateTime @default(now())

  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  subject     Subject  @relation(fields: [subjectId], references: [id])
}

model Mark {
  id                String    @id @default(uuid())
  examId            String
  studentId         String
  subjectId         String
  marksObtained     Float?
  maxMarks          Int
  grade             String?
  remarks           String?
  enteredBy         String
  enteredAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  status            String    @default("DRAFT")
  theoryMarks       Float?
  practicalMarks    Float?
  internalMarks     Float?
  isAbsent          Boolean   @default(false)
  isExempted        Boolean   @default(false)
  medicalLeave      Boolean   @default(false)
  coscholasticGrade String?
  coscholasticSports String?
  coscholasticArt   String?
  coscholasticDiscipline String?
  teacherRemarks    String?
  previousMarks     Float?
  verificationLevel Int       @default(0)
  verifiedByHod     String?
  verifiedByHodAt   DateTime?
  hodRemarks        String?
  approvedByPrincipal String?
  approvedByPrincipalAt DateTime?
  principalRemarks  String?
  recheckRequested  Boolean   @default(false)
  recheckReason     String?
  recheckFeePaid    Boolean   @default(false)
  recheckFeeAmount  Float?
  answerBookBarcode String?
  answerBookStatus  String?
  checkedBy         String?
  checkedAt         DateTime?
  returnedToOffice  Boolean   @default(false)
  blindEvaluation   Boolean   @default(false)

  exam              Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  student           Student   @relation(fields: [studentId], references: [id])
  subject           Subject   @relation(fields: [subjectId], references: [id])
  enteredByUser     User      @relation("MarkEnteredBy", fields: [enteredBy], references: [id])

  @@index([studentId])
  @@index([examId])
}

model ReportCard {
  id                String    @id @default(uuid())
  studentId         String
  academicYearId    String
  examId            String?
  totalMarks        Float
  maxTotalMarks     Float
  percentage        Float?
  overallGrade      String?
  rank              Int?
  totalStudents     Int?
  attendance        Int?
  workingDays       Int?
  scholastic        String?
  coScholastic      String?
  teacherRemarks    String?
  principalRemarks  String?
  pdfUrl            String?
  generatedAt       DateTime  @default(now())

  @@index([studentId])
}

// ==========================================
// TIMETABLE
// ==========================================

model Timetable {
  id          String   @id @default(uuid())
  schoolId    String
  classId     String
  sectionId   String
  dayOfWeek   Int
  period      Int
  subjectId   String
  teacherId   String
  startTime   String
  endTime     String
  roomNumber  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  class       Class    @relation(fields: [classId], references: [id])
  section     Section  @relation(fields: [sectionId], references: [id])

  @@index([classId, sectionId, dayOfWeek])
}

// ==========================================
// STAFF / HR MANAGEMENT
// ==========================================

model Staff {
  id                String    @id @default(uuid())
  userId            String?   @unique
  schoolId          String
  staffId           String
  employeeCode      String
  designation       String
  department        String
  qualification     String
  bEdQualified      Boolean   @default(false)
  mEdQualified      Boolean   @default(false)
  specialization    String?
  experience        Int       @default(0)
  dateOfJoining     DateTime
  dateOfLeaving     DateTime?
  employmentType    String    @default("Permanent")
  status            String    @default("Active")
  basicPay          Float
  bankAccount       String?
  bankIfsc          String?
  bankName          String?
  panNumber         String?
  uanNumber         String?
  esiNumber         String?
  photoUrl          String?
  idCardUrl         String?
  resumeUrl         String?
  certificates      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user              User?     @relation(fields: [userId], references: [id])
  attendance        Attendance[]
  leaves            LeaveApplication[]
  salaries          Salary[]

  @@index([schoolId])
  @@index([staffId])
  @@index([designation])
}

model Salary {
  id                String    @id @default(uuid())
  staffId           String
  userId            String
  month             Int
  year              Int
  basicPay          Float
  da                Float
  hra               Float
  ta                Float
  otherAllowances   Float     @default(0)
  grossSalary       Float
  pfEmployee        Float
  pfEmployer        Float
  esi               Float     @default(0)
  professionalTax   Float     @default(0)
  incomeTax         Float     @default(0)
  otherDeductions   Float     @default(0)
  totalDeductions   Float
  netSalary         Float
  status            String    @default("Pending")
  paidDate          DateTime?
  paymentMode       String?
  transactionId     String?
  payslipUrl        String?
  form16Url         String?
  remarks           String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  staff             Staff     @relation(fields: [staffId], references: [id])
  user              User      @relation(fields: [userId], references: [id])

  @@index([staffId])
}

model PayrollRecord {
  id                String    @id @default(uuid())
  academicYearId    String
  month             Int
  year              Int
  totalGross        Float
  totalDeductions   Float
  totalNet          Float
  staffCount        Int
  processedAt       DateTime  @default(now())
  processedBy       String

  academicYear      AcademicYear @relation(fields: [academicYearId], references: [id])
}

// ==========================================
// LIBRARY MANAGEMENT
// ==========================================

model LibraryBook {
  id                String    @id @default(uuid())
  schoolId          String
  isbn              String?
  title             String
  author            String
  publisher         String?
  category          String
  subCategory       String?
  edition           String?
  yearOfPublication Int?
  language          String    @default("English")
  price             Float?
  totalCopies       Int       @default(1)
  availableCopies   Int       @default(1)
  rackNumber        String?
  shelfNumber       String?
  status            String    @default("AVAILABLE")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  issues            BookIssue[]

  @@index([schoolId])
  @@index([isbn])
  @@index([category])
}

model BookIssue {
  id                String    @id @default(uuid())
  schoolId          String
  bookId            String
  studentId         String
  issueDate         DateTime  @default(now())
  dueDate           DateTime
  returnDate        DateTime?
  fineAmount        Float     @default(0)
  finePaid          Boolean   @default(false)
  status            String    @default("Issued")
  remarks           String?
  issuedBy          String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  book              LibraryBook @relation(fields: [bookId], references: [id])
  student           Student   @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([bookId])
  @@index([status])
}

// ==========================================
// TRANSPORT MANAGEMENT
// ==========================================

model TransportRoute {
  id                String    @id @default(uuid())
  schoolId          String
  routeNumber       String
  routeName         String
  startPoint        String
  endPoint          String
  totalDistance     Float?
  estimatedTime     Int?
  monthlyFee        Float
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  stops             TransportStop[]
  students          Student[]
  vehicles          Vehicle[]

  @@index([schoolId])
}

model TransportStop {
  id                String    @id @default(uuid())
  routeId           String
  stopName          String
  stopOrder         Int
  arrivalTime       String?
  departureTime     String?
  latitude          Float?
  longitude         Float?
  createdAt         DateTime  @default(now())

  route             TransportRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@index([routeId])
}

model Vehicle {
  id                String    @id @default(uuid())
  schoolId          String
  vehicleNumber     String
  vehicleType       String    @default("Bus")
  capacity          Int
  driverName        String
  driverPhone       String
  driverLicense     String?
  driverLicenseExpiry DateTime?
  conductorName     String?
  conductorPhone    String?
  fitnessCertificate String?
  fitnessExpiry     DateTime?
  insuranceNumber   String?
  insuranceExpiry   DateTime?
  status            String    @default("ACTIVE")
  gpsDeviceId       String?
  routeId           String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  route             TransportRoute? @relation(fields: [routeId], references: [id])

  @@index([schoolId])
}

// ==========================================
// HOSTEL MANAGEMENT
// ==========================================

model Hostel {
  id                String    @id @default(uuid())
  schoolId          String
  name              String
  type              String
  wardenId          String?
  capacity          Int
  address           String?
  phone             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  rooms             HostelRoom[]

  @@index([schoolId])
}

model HostelRoom {
  id                String    @id @default(uuid())
  hostelId          String
  roomNumber        String
  roomType          String
  capacity          Int
  occupied          Int       @default(0)
  monthlyFee        Float
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  hostel            Hostel    @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  allotments        HostelAllotment[]
}

model HostelAllotment {
  id                String    @id @default(uuid())
  studentId         String    @unique
  roomId            String
  allotmentDate     DateTime  @default(now())
  vacateDate        DateTime?
  monthlyFee        Float
  messFee           Float
  status            String    @default("Active")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  student           Student   @relation(fields: [studentId], references: [id])
  room              HostelRoom @relation(fields: [roomId], references: [id])

  @@index([roomId])
}

// ==========================================
// COMMUNICATION MODULE
// ==========================================

model Notice {
  id                String          @id @default(uuid())
  schoolId          String
  title             String
  content           String
  priority          String          @default("MEDIUM")
  target            String          @default("ALL")
  targetClassId     String?
  attachmentUrl     String?
  publishDate       DateTime        @default(now())
  expiryDate        DateTime?
  isActive          Boolean         @default(true)
  createdBy         String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  school            School          @relation(fields: [schoolId], references: [id])

  @@index([schoolId, isActive])
  @@index([publishDate])
}

model Communication {
  id                String          @id @default(uuid())
  schoolId          String
  type              String
  recipientIds      String
  message           String
  template          String?
  status            String          @default("Pending")
  sentAt            DateTime?
  sentBy            String
  createdAt         DateTime        @default(now())

  school            School          @relation(fields: [schoolId], references: [id])
  sender            User            @relation("CommSender", fields: [sentBy], references: [id])

  @@index([schoolId, type])
  @@index([status])
}

// ==========================================
// ACADEMIC MODULE
// ==========================================

model Homework {
  id                String    @id @default(uuid())
  schoolId          String
  subjectId         String
  classId           String
  sectionId         String?
  title             String
  description       String
  attachmentUrl     String?
  dueDate           DateTime
  maxMarks          Int?
  assignedBy        String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  subject           Subject   @relation(fields: [subjectId], references: [id])
  submissions       HomeworkSubmission[]

  @@index([classId, dueDate])
  @@index([subjectId])
}

model HomeworkSubmission {
  id                String    @id @default(uuid())
  homeworkId        String
  studentId         String
  submissionUrl     String?
  marksObtained     Float?
  remarks           String?
  submittedAt       DateTime  @default(now())
  gradedAt          DateTime?
  gradedBy          String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  homework          Homework  @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  student           Student   @relation(fields: [studentId], references: [id])

  @@index([studentId])
}

model StudyMaterial {
  id                String    @id @default(uuid())
  schoolId          String
  classId           String
  sectionId         String?
  subjectId         String?
  title             String
  description       String?
  fileUrl           String
  fileType          String
  uploadedBy        String
  createdAt         DateTime  @default(now())

  @@index([classId])
  @@index([subjectId])
}

// ==========================================
// AUDIT & SYSTEM
// ==========================================

model AuditLog {
  id                String    @id @default(uuid())
  schoolId          String
  userId            String
  action            String
  entityType        String
  entityId          String
  oldValue          String?
  newValue          String?
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime  @default(now())

  user              User      @relation(fields: [userId], references: [id])

  @@index([schoolId, entityType, entityId])
  @@index([userId, createdAt])
  @@index([createdAt])
}

model Session {
  id                String    @id @default(uuid())
  userId            String
  token             String
  ipAddress         String?
  userAgent         String?
  expiresAt         DateTime
  createdAt         DateTime  @default(now())

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

// ==========================================
// EXAMINATION ENHANCEMENTS
// ==========================================

model ExamSchedule {
  id          String   @id @default(uuid())
  examId      String
  subjectId   String
  date        DateTime
  dayOfWeek   String
  startTime   String
  endTime     String
  roomNumber  String?
  createdAt   DateTime @default(now())

  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([examId])
  @@index([date])
}

model SeatingArrangement {
  id          String   @id @default(uuid())
  examId      String
  studentId   String
  roomId      String
  rowNumber   Int
  seatNumber  Int
  invigilatorId String?
  createdAt   DateTime @default(now())

  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  room        ExamRoom @relation(fields: [roomId], references: [id])

  @@unique([examId, studentId])
  @@index([examId, roomId])
}

model ExamRoom {
  id          String   @id @default(uuid())
  schoolId    String
  roomNumber  String
  capacity    Int
  floor       String?
  building    String?
  createdAt   DateTime @default(now())

  seatingArrangements SeatingArrangement[]
  invigilatorDuties   InvigilatorDuty[]

  @@index([schoolId])
}

model InvigilatorDuty {
  id          String   @id @default(uuid())
  examId      String
  roomId      String
  teacherId   String
  date        DateTime
  shift       String
  createdAt   DateTime @default(now())

  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  room        ExamRoom @relation(fields: [roomId], references: [id])

  @@index([examId, teacherId])
}

model AnswerBook {
  id          String   @id @default(uuid())
  schoolId    String
  barcode     String   @unique
  examId      String?
  studentId   String?
  subjectId   String?
  status      String   @default("UNUSED")
  distributedAt DateTime?
  collectedAt DateTime?
  checkedBy   String?
  checkedAt   DateTime?
  marksEntered Boolean @default(false)
  returnedToOffice Boolean @default(false)
  createdAt   DateTime @default(now())

  exam        Exam?    @relation(fields: [examId], references: [id])

  @@index([schoolId, status])
  @@index([barcode])
}

model MarkVerificationLog {
  id          String   @id @default(uuid())
  markId      String
  action      String
  performedBy String
  reason      String?
  oldValue    String?
  newValue    String?
  createdAt   DateTime @default(now())

  @@index([markId])
  @@index([performedBy])
}

model CompartmentExam {
  id          String   @id @default(uuid())
  schoolId    String
  parentExamId String
  name        String
  startDate   DateTime
  endDate     DateTime
  feeAmount   Float
  status      String   @default("SCHEDULED")
  createdAt   DateTime @default(now())

  students    CompartmentStudent[]

  @@index([schoolId])
}

model CompartmentStudent {
  id          String   @id @default(uuid())
  compartmentId String
  studentId   String
  subjectId   String
  originalMarks Float
  status      String   @default("PENDING")
  newMarks    Float?
  newGrade    String?
  feePaid     Boolean  @default(false)
  feePaymentId String?
  noticeSent  Boolean  @default(false)
  createdAt   DateTime @default(now())

  compartment CompartmentExam @relation(fields: [compartmentId], references: [id])

  @@unique([compartmentId, studentId, subjectId])
}

model MeritCertificate {
  id          String   @id @default(uuid())
  schoolId    String
  studentId   String
  examId      String
  certificateType String
  rank        Int
  pdfUrl      String?
  generatedAt DateTime @default(now())

  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([studentId, examId, certificateType])
  @@index([schoolId])
}

model StudentHealthRecord {
  id          String   @id @default(uuid())
  studentId   String
  academicYear String
  height      Float?
  weight      Float?
  bloodGroup  String?
  vision      String?
  dental      String?
  generalHealth String?
  recordedAt  DateTime @default(now())

  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, academicYear])
}

model RecheckApplication {
  id          String   @id @default(uuid())
  schoolId    String
  studentId   String
  examId      String
  subjectId   String
  reason      String
  status      String   @default("PENDING")
  feeAmount   Float
  feePaid     Boolean  @default(false)
  appliedAt   DateTime @default(now())
  processedAt DateTime?
  processedBy String?
  newMarks    Float?
  remarks     String?

  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
  @@index([studentId])
}

// ==========================================
// PHASE 3 FEATURES
// ==========================================

// Feature 11: Income & Expense Ledger
model LedgerEntry {
  id          String   @id @default(uuid())
  schoolId    String
  type        String   // INCOME or EXPENSE
  category    String   // fee, salary, donation, maintenance, etc.
  amount      Float
  date        DateTime
  description String?
  reference   String?  // receipt number, invoice, etc.
  paymentMode String?
  createdBy   String
  createdAt   DateTime @default(now())

  @@index([schoolId, type, date])
  @@index([schoolId, category])
}

// Feature 12: RTE Quota
model RTEQuota {
  id               String   @id @default(uuid())
  schoolId         String
  academicYearId   String
  classId          String
  totalSeats       Int
  rteSeats         Int      // 25% of total
  filledSeats      Int      @default(0)
  reimbursementAmount Float?
  reimbursementStatus String @default("Pending")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([schoolId, academicYearId, classId])
}

// Feature 13: Syllabus & Lesson Plan
model Syllabus {
  id          String   @id @default(uuid())
  schoolId    String
  classId     String
  subjectId   String
  chapterName String
  chapterNumber Int
  description String?
  isCompleted Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([schoolId, classId, subjectId])
}

model LessonPlan {
  id          String   @id @default(uuid())
  schoolId    String
  teacherId   String
  classId     String
  subjectId   String
  topic       String
  date        DateTime
  period      Int
  objectives  String?
  methodology String?  // 5E format
  resources   String?
  assessment  String?
  createdAt   DateTime @default(now())

  @@index([teacherId, date])
}

// Feature 15: WhatsApp Notifications
model WhatsAppMessage {
  id          String   @id @default(uuid())
  schoolId    String
  recipientIds String   // comma-separated IDs
  messageType String   // fee_reminder, result, absent, holiday, ptm, circular
  template    String
  variables   String   // JSON of template variables
  status      String   @default("Pending")
  sentAt      DateTime?
  messageId   String?
  createdAt   DateTime @default(now())

  @@index([schoolId, status])
  @@index([messageType])
}

// Feature 16: Merit Certificate
model MeritList {
  id          String   @id @default(uuid())
  schoolId    String
  examId      String
  classId     String
  studentId   String
  rank        Int
  percentage  Float
  totalMarks  Float
  maxMarks    Float
  certificateGenerated Boolean @default(false)
  certificateUrl String?
  createdAt   DateTime @default(now())

  @@unique([examId, studentId])
  @@index([schoolId, examId, classId])
}

// Feature 17: Character Certificate
model CharacterCertificate {
  id          String   @id @default(uuid())
  schoolId    String
  studentId   String
  certificateNumber String @unique
  fromYear    String
  toYear      String
  classStudied String
  character   String   // Good/Excellent
  issuedAt    DateTime @default(now())
  pdfUrl      String?

  @@index([schoolId, studentId])
}

// Feature 18: Sibling Discount
model SiblingLink {
  id          String   @id @default(uuid())
  schoolId    String
  primaryStudentId String
  siblingStudentId String
  discountPercentage Float
  createdAt   DateTime @default(now())

  @@unique([primaryStudentId, siblingStudentId])
  @@index([schoolId])
}

model TokenBlacklist {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiry    DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordHistory {
  id             String   @id @default(uuid())
  userId         String
  hashedPassword String
  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
