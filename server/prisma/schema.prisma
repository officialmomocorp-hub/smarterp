generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AcademicYear {
  id            String          @id
  schoolId      String
  name          String
  startDate     DateTime
  endDate       DateTime
  status        String          @default("ACTIVE")
  isCurrent     Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  school        School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  admissions     Admission[]
  classes         Class[]
  exams          Exam[]
  feePayments    FeePayment[]
  holidaies       Holiday[]
  notices        Notice[]
  payrollRecords PayrollRecord[]
  rTEQuotas      RTEQuota[]
  reportCards    ReportCard[]
  students       Student[]
  timetables     Timetable[]

  @@index([schoolId, isCurrent])
}

model Admission {
  id                 String       @id
  schoolId           String
  academicYearId     String
  admissionNumber    String       @unique
  applicantName      String
  applicantPhone     String
  applicantEmail     String?
  classApplied       String
  sectionPreferred   String?
  dateOfBirth        DateTime
  gender             String
  casteCategory      String
  religion           String
  motherTongue       String
  aadharNumber       String?
  previousSchool     String?
  previousClass      String?
  tcNumber           String?
  tcDate             DateTime?
  reasonForLeaving   String?
  fatherName         String?
  fatherOccupation   String?
  fatherPhone        String?
  motherName         String?
  motherOccupation   String?
  motherPhone        String?
  annualIncome       Float?
  address            String?
  city               String?
  state              String?
  pincode            String?
  status             String       @default("PENDING")
  remarks            String?
  documents          String?
  admissionFeePaid   Boolean      @default(false)
  admissionFeeAmount Float?
  submittedAt        DateTime     @default(now())
  processedAt        DateTime?
  processedBy        String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime
  academicYear       AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  school             School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student            Student?

  @@index([admissionNumber])
  @@index([schoolId, status])
}

model AnswerBook {
  id               String    @id
  schoolId         String
  barcode          String    @unique
  examId           String?
  studentId        String?
  subjectId        String?
  status           String    @default("UNUSED")
  distributedAt    DateTime?
  collectedAt      DateTime?
  checkedBy        String?
  checkedAt        DateTime?
  marksEntered     Boolean   @default(false)
  returnedToOffice Boolean   @default(false)
  createdAt        DateTime  @default(now())
  user             User?     @relation(fields: [checkedBy], references: [id], onDelete: Cascade)
  exam             Exam?     @relation(fields: [examId], references: [id], onDelete: Cascade)
  school           School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student          Student?  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject          Subject?  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([barcode])
  @@index([schoolId, status])
}

model Attendance {
  id           String    @id
  schoolId     String
  studentId    String?
  staffId      String?
  userId       String?
  date         DateTime
  period       Int?
  status       String
  remarks      String?
  markedBy     String
  markedAt     DateTime  @default(now())
  biometricId  String?
  checkInTime  DateTime?
  checkOutTime DateTime?
  lateMinutes  Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime
  school       School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  staff        Staff?    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  student      Student?  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  user         User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([schoolId, date])
  @@index([staffId, date])
  @@index([studentId, date])
}

model AuditLog {
  id         String   @id
  schoolId   String
  userId     String
  action     String
  resource   String
  resourceId String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([resource, resourceId])
  @@index([schoolId, createdAt])
  @@index([userId, createdAt])
}

model BookIssue {
  id          String      @id
  schoolId    String
  bookId      String
  studentId   String
  issueDate   DateTime    @default(now())
  dueDate     DateTime
  returnDate  DateTime?
  fineAmount  Float       @default(0)
  finePaid    Boolean     @default(false)
  status      String      @default("Issued")
  remarks     String?
  issuedBy    String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime
  libraryBook LibraryBook @relation(fields: [bookId], references: [id], onDelete: Cascade)
  school      School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student     Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@index([status])
  @@index([studentId])
}

model CharacterCertificate {
  id                String   @id
  schoolId          String
  studentId         String
  certificateNumber String   @unique
  fromYear          String
  toYear            String
  classStudied      String
  character         String
  issuedAt          DateTime @default(now())
  pdfUrl            String?
  school            School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student           Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId, studentId])
}

model Class {
  id                   String                 @id
  schoolId             String
  academicYearId       String
  name                 String
  displayName          String
  sortOrder            Int
  hasCce               Boolean                @default(false)
  isBoardClass         Boolean                @default(false)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  academicYear         AcademicYear           @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  school               School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  exams                 Exam[]
  feePaymentConcessions FeePaymentConcession[]
  feeStructures         FeeStructure[]
  homeworks             Homework[]
  lessonPlans           LessonPlan[]
  meritLists            MeritList[]
  notices               Notice[]
  rTEQuotas             RTEQuota[]
  sections              Section[]
  students              Student[]
  studyMaterials        StudyMaterial[]
  subjects              Subject[]
  syllabuss             Syllabus[]
  timetables            Timetable[]

  @@index([schoolId, academicYearId])
}

model Communication {
  id           String    @id
  schoolId     String
  type         String
  recipientIds String
  message      String
  template     String?
  status       String    @default("Pending")
  sentAt       DateTime?
  sentBy       String
  createdAt    DateTime  @default(now())
  school       School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [sentBy], references: [id], onDelete: Cascade)

  @@index([schoolId, type])
  @@index([status])
}

model CompartmentExam {
  id                 String               @id
  schoolId           String
  parentExamId       String
  name               String
  startDate          DateTime
  endDate            DateTime
  feeAmount          Float
  status             String               @default("SCHEDULED")
  createdAt          DateTime             @default(now())
  exam               Exam                 @relation(fields: [parentExamId], references: [id], onDelete: Cascade)
  school             School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  compartmentStudents CompartmentStudent[]

  @@index([schoolId])
}

model CompartmentStudent {
  id                  String                @id
  compartmentId       String
  studentId           String
  subjectId           String
  originalMarks       Float
  status              String                @default("PENDING")
  newMarks            Float?
  newGrade            String?
  feePaid             Boolean               @default(false)
  feePaymentId        String?
  noticeSent          Boolean               @default(false)
  createdAt           DateTime              @default(now())
  compartmentExam     CompartmentExam       @relation(fields: [compartmentId], references: [id], onDelete: Cascade)
  student             Student               @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject             Subject               @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  markVerificationLogs MarkVerificationLog[]

  @@unique([compartmentId, studentId, subjectId])
}

model Exam {
  id                 String               @id
  schoolId           String
  academicYearId     String
  classId            String
  name               String
  type               String
  startDate          DateTime
  endDate            DateTime
  maxMarks           Int                  @default(100)
  passMarks          Int                  @default(33)
  weightage          Float                @default(100)
  isCce              Boolean              @default(false)
  scholastic         Boolean              @default(true)
  coScholastic       Boolean              @default(false)
  resultsPublished   Boolean              @default(false)
  boardType          String?
  graceMarks         Float                @default(0)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  answerBooks         AnswerBook[]
  compartmentExams    CompartmentExam[]
  academicYear       AcademicYear         @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  class              Class                @relation(fields: [classId], references: [id], onDelete: Cascade)
  school             School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  examSchedules       ExamSchedule[]
  examSubjects        ExamSubject[]
  invigilatorDuties    InvigilatorDuty[]
  marks               Mark[]
  meritCertificates   MeritCertificate[]
  meritLists          MeritList[]
  recheckApplications RecheckApplication[]
  reportCards         ReportCard[]
  seatingArrangements SeatingArrangement[]

  @@index([schoolId, academicYearId, classId])
}

model ExamRoom {
  id                 String               @id
  schoolId           String
  roomNumber         String
  capacity           Int
  floor              String?
  building           String?
  createdAt          DateTime             @default(now())
  school             School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  invigilatorDuties    InvigilatorDuty[]
  seatingArrangements SeatingArrangement[]

  @@index([schoolId])
}

model ExamSchedule {
  id         String   @id
  examId     String
  subjectId  String
  date       DateTime
  dayOfWeek  String
  startTime  String
  endTime    String
  roomNumber String?
  createdAt  DateTime @default(now())
  exam       Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([examId])
}

model ExamSubject {
  id        String   @id
  examId    String
  subjectId String
  maxMarks  Int      @default(100)
  passMarks Int      @default(33)
  createdAt DateTime @default(now())
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}

model FeeConcession {
  id                   String                 @id
  feeStructureId       String
  name                 String
  type                 String
  discountType         String
  discountValue        Float
  applicableCaste      String
  applicableIncome     Float?
  maxDiscountAmount    Float?
  description          String?
  isActive             Boolean                @default(true)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  feeStructure         FeeStructure           @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)
  feePayments           FeePayment[]
  feePaymentConcessions FeePaymentConcession[]

  @@index([feeStructureId])
}

model FeePayment {
  id                   String                 @id
  schoolId             String
  academicYearId       String
  studentId            String
  feeStructureId       String
  concessionId         String?
  receiptNumber        String
  installmentNumber    Int
  dueDate              DateTime
  paymentDate          DateTime?
  totalAmount          Float
  concessionAmount     Float                  @default(0)
  gstAmount            Float                  @default(0)
  lateFine             Float                  @default(0)
  paidAmount           Float                  @default(0)
  balanceAmount        Float
  status               String                 @default("PENDING")
  paymentMode          String?
  transactionId        String?
  bankName             String?
  chequeNumber         String?
  chequeDate           DateTime?
  razorpayOrderId      String?
  razorpayPaymentId    String?
  remarks              String?
  receiptUrl           String?
  createdBy            String
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  academicYear         AcademicYear           @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  feeConcession        FeeConcession?         @relation(fields: [concessionId], references: [id], onDelete: Cascade)
  feeStructure         FeeStructure           @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)
  school               School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student              Student                @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feePaymentConcessions FeePaymentConcession[]

  @@index([dueDate])
  @@index([receiptNumber])
  @@index([status])
  @@index([studentId, academicYearId])
}

model FeePaymentConcession {
  id            String        @id
  feePaymentId  String
  concessionId  String
  amount        Float
  classId       String?
  schoolId      String
  class         Class?        @relation(fields: [classId], references: [id], onDelete: Cascade)
  feeConcession FeeConcession @relation(fields: [concessionId], references: [id], onDelete: Cascade)
  feePayment    FeePayment    @relation(fields: [feePaymentId], references: [id], onDelete: Cascade)
  school        School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([feePaymentId, concessionId])
}

model FeeStructure {
  id              String          @id
  schoolId        String
  academicYearId  String
  classId         String
  name            String
  feeHeads        String
  totalAmount     Float
  installmentType String          @default("QUARTERLY")
  dueDates        String
  lateFinePerDay  Float           @default(0)
  gstPercentage   Float           @default(0)
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  feeConcessions   FeeConcession[]
  feePayments      FeePayment[]
  class           Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  school          School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, academicYearId, classId])
}

model Holiday {
  id             String        @id
  schoolId       String
  name           String
  date           DateTime
  type           String
  description    String?
  isNational     Boolean       @default(false)
  isState        Boolean       @default(false)
  createdAt      DateTime      @default(now())
  academicYearId String?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  school         School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, date])
}

model Homework {
  id                 String               @id
  schoolId           String
  subjectId          String
  classId            String
  sectionId          String?
  title              String
  description        String
  attachmentUrl      String?
  dueDate            DateTime
  maxMarks           Int?
  assignedBy         String
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  user               User                 @relation(fields: [assignedBy], references: [id], onDelete: Cascade)
  class              Class                @relation(fields: [classId], references: [id], onDelete: Cascade)
  school             School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  section            Section?             @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subject            Subject              @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  homeworkSubmissions HomeworkSubmission[]

  @@index([classId, dueDate])
  @@index([subjectId])
}

model HomeworkSubmission {
  id            String    @id
  homeworkId    String
  studentId     String
  submissionUrl String?
  marksObtained Float?
  remarks       String?
  submittedAt   DateTime  @default(now())
  gradedAt      DateTime?
  gradedBy      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  homework      Homework  @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  student       Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

model Hostel {
  id         String       @id
  schoolId   String
  name       String
  type       String
  wardenId   String?
  capacity   Int
  address    String?
  phone      String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime
  school     School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  hostelRooms HostelRoom[]

  @@index([schoolId])
}

model HostelAllotment {
  id            String     @id
  studentId     String     @unique
  roomId        String
  allotmentDate DateTime   @default(now())
  vacateDate    DateTime?
  monthlyFee    Float
  messFee       Float
  status        String     @default("Active")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime
  hostelRoom    HostelRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  student       Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([roomId])
}

model HostelRoom {
  id              String            @id
  hostelId        String
  roomNumber      String
  roomType        String
  capacity        Int
  occupied        Int               @default(0)
  monthlyFee      Float
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  hostelAllotments HostelAllotment[]
  hostel          Hostel            @relation(fields: [hostelId], references: [id], onDelete: Cascade)
}

model InvigilatorDuty {
  id        String   @id
  examId    String
  roomId    String
  teacherId String
  date      DateTime
  shift     String
  createdAt DateTime @default(now())
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  examRoom  ExamRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([examId, teacherId])
}

model LeaveApplication {
  id              String    @id
  schoolId        String
  studentId       String?
  staffId         String?
  userId          String?
  startDate       DateTime
  endDate         DateTime
  leaveType       String
  reason          String
  status          String    @default("PENDING")
  appliedBy       String
  approvedBy      String?
  approvedAt      DateTime?
  rejectionReason String?
  attachmentUrl   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime
  school          School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  staff           Staff?    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  student         Student?  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  user            User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
  @@index([staffId])
  @@index([studentId])
}

model LedgerEntry {
  id          String   @id
  schoolId    String
  type        String
  category    String
  amount      Float
  date        DateTime
  description String?
  reference   String?
  paymentMode String?
  createdBy   String
  createdAt   DateTime @default(now())
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, category])
  @@index([schoolId, type, date])
}

model LessonPlan {
  id          String   @id
  schoolId    String
  teacherId   String
  classId     String
  subjectId   String
  topic       String
  date        DateTime
  period      Int
  objectives  String?
  methodology String?
  resources   String?
  assessment  String?
  createdAt   DateTime @default(now())
  sectionId   String?
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  section     Section? @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId, date])
}

model LibraryBook {
  id                String      @id
  schoolId          String
  isbn              String?
  title             String
  author            String
  publisher         String?
  category          String
  subCategory       String?
  edition           String?
  yearOfPublication Int?
  language          String      @default("English")
  price             Float?
  totalCopies       Int         @default(1)
  availableCopies   Int         @default(1)
  rackNumber        String?
  shelfNumber       String?
  status            String      @default("AVAILABLE")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime
  bookIssues         BookIssue[]
  school            School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([isbn])
  @@index([schoolId])
}

model Mark {
  id                     String                @id
  examId                 String
  studentId              String
  subjectId              String
  marksObtained          Float?
  maxMarks               Int
  grade                  String?
  remarks                String?
  enteredBy              String
  enteredAt              DateTime              @default(now())
  updatedAt              DateTime
  status                 String                @default("DRAFT")
  theoryMarks            Float?
  practicalMarks         Float?
  internalMarks          Float?
  isAbsent               Boolean               @default(false)
  isExempted             Boolean               @default(false)
  medicalLeave           Boolean               @default(false)
  coscholasticGrade      String?
  coscholasticSports     String?
  coscholasticArt        String?
  coscholasticDiscipline String?
  teacherRemarks         String?
  previousMarks          Float?
  verificationLevel      Int                   @default(0)
  verifiedByHod          String?
  verifiedByHodAt        DateTime?
  hodRemarks             String?
  approvedByPrincipal    String?
  approvedByPrincipalAt  DateTime?
  principalRemarks       String?
  recheckRequested       Boolean               @default(false)
  recheckReason          String?
  recheckFeePaid         Boolean               @default(false)
  recheckFeeAmount       Float?
  answerBookBarcode      String?
  answerBookStatus       String?
  checkedBy              String?
  checkedAt              DateTime?
  returnedToOffice       Boolean               @default(false)
  blindEvaluation        Boolean               @default(false)
  schoolId               String
  user                   User                  @relation(fields: [enteredBy], references: [id], onDelete: Cascade)
  exam                   Exam                  @relation(fields: [examId], references: [id], onDelete: Cascade)
  school                 School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student                Student               @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject                Subject               @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  markVerificationLogs    MarkVerificationLog[]
  recheckApplications     RecheckApplication[]

  @@index([examId])
  @@index([schoolId])
  @@index([studentId])
}

model MarkVerificationLog {
  id                   String              @id
  markId               String
  action               String
  performedBy          String
  reason               String?
  oldValue             String?
  newValue             String?
  createdAt            DateTime            @default(now())
  compartmentStudentId String?
  schoolId             String
  subjectId            String?
  compartmentStudent   CompartmentStudent? @relation(fields: [compartmentStudentId], references: [id], onDelete: Cascade)
  mark                 Mark                @relation(fields: [markId], references: [id], onDelete: Cascade)
  school               School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject              Subject?            @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([markId])
  @@index([performedBy])
  @@index([schoolId])
}

model MeritCertificate {
  id              String   @id
  schoolId        String
  studentId       String
  examId          String
  certificateType String
  rank            Int
  pdfUrl          String?
  generatedAt     DateTime @default(now())
  exam            Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  school          School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, examId, certificateType])
  @@index([schoolId])
}

model MeritList {
  id                   String   @id
  schoolId             String
  examId               String
  classId              String
  studentId            String
  rank                 Int
  percentage           Float
  totalMarks           Float
  maxMarks             Float
  certificateGenerated Boolean  @default(false)
  certificateUrl       String?
  createdAt            DateTime @default(now())
